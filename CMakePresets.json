{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 0,
        "patch": 0
    },
    "$comment": "gkit library build configration for different platforms",
    "configurePresets": [
        {
            "name": "common",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}"
        },

        {"name": "linux" },
        {"name": "windows" },

        {"name": "x64", "architecture": "x64"},
        {"name": "x86", "architecture": "x86"},
        {"name": "arm64", "architecture": "arm64"},
        {"name": "arm", "architecture": "arm"},

        {"name": "debug", "cacheVariables": {"CMAKE_BUILD_TYPE": "Debug"}},
        {"name": "release", "cacheVariables": {"CMAKE_BUILD_TYPE": "Release"}},

        {"name": "gcc", "cacheVariables": {"CMAKE_C_COMPILER": "gcc", "CMAKE_CXX_COMPILER": "g++"}},

        {"name": "c_abi", "cacheVariables": {"EXPORT_C_ABI": {"type": "BOOL", "value": true}}}, 
        {"name": "c_abi", "cacheVariables": {"EXPORT_C_ABI": {"type": "BOOL", "value": false}}}, 

        {
            "name": "linux-x86_64-gcc-debug",
            "inherits": ["common", "linux", "x64", "debug", "gcc", "c_abi"],
            "cacheVariables": {
                "BIN_FOLDER": "linux-x86_64-gcc"
            }
        },
        {
            "name": "linux-x86_64-gcc-noabi-debug",
            "inherits": ["common", "linux", "x64", "debug", "gcc"],
            "cacheVariables": {
                "BIN_FOLDER": "linux-x86_64-gcc"
            }
        },
        {
            "name": "windows-x86_64-mingw64-debug",
            "inherits": ["common", "windows", "x64", "debug", "c_abi"],
            "cacheVariables": {
                "BIN_FOLDER": "windows-x86_64-gcc"
            }
        },
        {
            "name": "windows-x86_64-mingw64-debug",
            "inherits": ["common", "windows", "x64", "debug"],
            "cacheVariables": {
                "BIN_FOLDER": "windows-x86_64-gcc"
            }
        }
    ]
}